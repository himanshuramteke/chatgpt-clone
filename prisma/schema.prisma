generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum MessageRole {
  USER 
  ASSISTANT 
  SYSTEM 
  TOOL
}

enum MessageStatus {
  PENDING
  COMPLETE
  ERROR
}

model User {
  id         String  @id @default(uuid())
  clerkId    String  @unique
  email      String? @unique
  firstName  String?
  lastName   String?
  imageUrl   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  conversations Conversation[]
}

model Conversation {
  id            String @id @default(cuid())
  userId        String
  title         String @default("New Chat")
  model         String? 
  systemPrompt  String? @db.Text
  isPinned      Boolean @default(false)
  isArchived    Boolean @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  lastMessageAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  message Message[]
  branch  Branch[]

  @@index([userId, lastMessageAt(sort: Desc)])
  @@index([userId, isPinned, lastMessageAt(sort: Desc)])
}


model Message {
  id              String @id @default(cuid())
  conversationId  String
  parentId        String?
  role            MessageRole
   status         MessageStatus @default(COMPLETE)
   content        String @db.Text
   parts          Json?  // 
   metadata       Json? 

   conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
   parent       Message?     @relation("MessageTree", fields: [parentId], references: [id], onDelete: SetNull)
   children     Message[]    @relation("MessageTree")
   branchAsLeaf Branch[]     @relation("BranchLeaf")

   createdAt DateTime @default(now())
   updatedAt DateTime @updatedAt

   @@index([conversationId, createdAt(sort: Desc)])
   @@index([parentId])
}

model Branch {
  id                    String @id @default(cuid())
  conversationId        String
  name                  String
  leafMessageId         String?
  branchPointMessageId  String?
  isDefault             Boolean @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  conversation          Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  leafMessage           Message?     @relation("BranchLeaf", fields: [leafMessageId], references: [id], onDelete: SetNull)

  @@index([conversationId])
}